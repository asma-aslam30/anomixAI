# Google Gemini API key — obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Revenue used to calculate business impact of incidents (Pakistani Rupees per minute of downtime)
REVENUE_PER_MINUTE_PKR=50000

# Z-score threshold above which a metric is flagged as a spike (default: 2.0)
Z_SCORE_THRESHOLD=2.0

# Set to "true" to log alert emails to the console instead of sending them via SMTP
MOCK_EMAIL=true

# Recipient address for incident alert emails
ALERT_EMAIL=alerts@sentinelai.local

# Endpoint for the WhatsApp webhook mock (used in local dev; replace with real URL in production)
WHATSAPP_WEBHOOK_URL=http://localhost:9000/mock-webhook
